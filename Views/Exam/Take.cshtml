@model List<EmployeeTrainer.Models.ExamTask>
@using EmployeeTrainer.Models

@{
    ViewData["Title"] = "Экзамен";
    var exam = ViewBag.Exam as Exam;
    var timeLimit = exam?.TimeLimitMinutes ?? 0;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between mb-3">
        <h2>@exam?.Title</h2>
        @if (timeLimit > 0) { <div class="text-center"><div class="display-6 fw-bold text-danger" id="timer">@timeLimit:00</div><small>осталось</small></div> }
    </div>
    <p class="text-muted">@exam?.Description</p>
    <div class="alert alert-warning">⚠️ Не покидайте страницу — экзамен отправится автоматически.</div>

    <form method="post" action="/Exam/Submit" id="examForm">
        <input type="hidden" name="examId" value="@exam?.Id" />
        @foreach (var task in Model)
        {
            var options = string.IsNullOrEmpty(task.OptionsJson) ? new() : task.OptionsJson.Split('|').Select(o => o.Trim()).ToList();
            <div class="card mb-3">
                <div class="card-header">@(task.Type == ExamTaskType.Single ? "○ Один" : task.Type == ExamTaskType.Multiple ? "☑️ Несколько" : "✍️ Свободный")</div>
                <div class="card-body">
                    <h5>@task.Title</h5><p>@task.Question</p>
                    @if (!string.IsNullOrEmpty(task.ImageUrl)) { <img src="@task.ImageUrl" class="img-fluid rounded mb-3" style="max-height:250px;" /> }
                    @if (task.Type == ExamTaskType.Single) { for (int i = 0; i < options.Count; i++) { <div class="form-check"><input class="form-check-input" type="radio" name="answer_@task.Id" value="@i" /><label class="form-check-label">@options[i]</label></div> } }
                    else if (task.Type == ExamTaskType.Multiple) { for (int i = 0; i < options.Count; i++) { <div class="form-check"><input class="form-check-input" type="checkbox" name="answer_@task.Id" value="@i" /><label class="form-check-label">@options[i]</label></div> } }
                    else { <textarea name="answer_@task.Id" class="form-control" rows="3" placeholder="Ваш ответ..."></textarea> }
                </div>
            </div>
        }
        <button type="button" class="btn btn-primary btn-lg" onclick="confirmSubmit()">📤 Отправить</button>
    </form>
</div>

<div class="modal fade" id="confirmModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5>📤 Отправить?</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><p>Завершить экзамен и отправить на проверку?</p></div><div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button><button class="btn btn-primary" onclick="submitExam()">✅ Да</button></div></div></div></div>
<div class="modal fade" id="startModal" tabindex="-1" data-bs-backdrop="static"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5>📋 Начать экзамен?</h5></div><div class="modal-body"><p><strong>@exam?.Title</strong></p><p>Заданий: @Model.Count</p>@if (timeLimit > 0) { <p>⏱️ @timeLimit мин</p> }<p class="text-danger">⚠️ Не покидайте страницу!</p></div><div class="modal-footer"><a href="/Exam" class="btn btn-secondary">↩ К списку</a><button class="btn btn-primary" data-bs-dismiss="modal" onclick="startExam()">✅ Начать</button></div></div></div></div>

@section Scripts {
    <script>
        var examStarted = false, elapsed = 0, timerInterval;
        window.addEventListener('DOMContentLoaded', function() { new bootstrap.Modal(document.getElementById('startModal')).show(); });
        function startExam() { examStarted = true; if (@timeLimit > 0) { timerInterval = setInterval(function() { elapsed++; var rem = @timeLimit * 60 - elapsed; if (rem <= 0) { clearInterval(timerInterval); alert('Время вышло!'); document.getElementById('examForm').submit(); } else { document.getElementById('timer').textContent = Math.floor(rem/60) + ':' + (rem%60 < 10 ? '0' : '') + rem%60; } }, 1000); } }
        function confirmSubmit() { if (!examStarted) return; new bootstrap.Modal(document.getElementById('confirmModal')).show(); }
        function submitExam() { document.getElementById('examForm').submit(); }
        window.addEventListener('beforeunload', function(e) { if (examStarted) { navigator.sendBeacon('/Exam/Submit', new FormData(document.getElementById('examForm'))); } });
    </script>
}