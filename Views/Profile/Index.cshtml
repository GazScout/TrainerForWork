@model List<EmployeeTrainer.Models.TestResult>
@using System.Security.Claims
@using EmployeeTrainer.Models

@{
    ViewData["Title"] = "Мой профиль";
    var user = ViewBag.User as User;
}

<div class="container mt-4">
    <h2>👤 Мой профиль</h2>

    <div class="card mb-4"><div class="card-body"><div class="row"><div class="col-md-6"><h4>@(user?.FullName ?? User.FindFirstValue(ClaimTypes.GivenName))</h4><p class="text-muted">Логин: <strong>@User.Identity?.Name</strong><br />Роль: @if (User.IsInRole("SuperAdmin")) { <span class="badge bg-warning text-dark">👑 Супер-админ</span> } else if (User.IsInRole("Admin")) { <span class="badge bg-primary">👑 Админ</span> } else { <span class="badge bg-secondary">👤 Сотрудник</span> }</p></div><div class="col-md-6 text-end"><a href="/Auth/Logout" class="btn btn-outline-danger">🚪 Выйти</a></div></div></div></div>

    <div class="card mb-4"><div class="card-body"><div class="d-flex justify-content-between mb-2"><strong>📊 Общий прогресс</strong><span>@ViewBag.OverallProgress%</span></div><div class="progress" style="height:25px;"><div class="progress-bar progress-bar-striped progress-bar-animated @(ViewBag.OverallProgress >= 80 ? "bg-success" : ViewBag.OverallProgress >= 40 ? "bg-warning" : "bg-danger")" style="width:@ViewBag.OverallProgress%;">@ViewBag.OverallProgress%</div></div><small class="text-muted mt-1">@ViewBag.CompletedTests тестов, @ViewBag.CompletedExams экзаменов, @ViewBag.CompletedTasks заданий</small></div></div>

    <div class="row mb-4">
        <div class="col-md-3"><div class="card text-center border-primary"><div class="card-body"><h1 class="display-4 text-primary">@ViewBag.CompletedTests / @ViewBag.TotalTests</h1><p>Пройдено тестов</p></div></div></div>
        <div class="col-md-3"><div class="card text-center border-info"><div class="card-body"><h1 class="display-4 text-info">@ViewBag.TotalAttempts</h1><p>Всего попыток</p></div></div></div>
        <div class="col-md-3"><div class="card text-center border-success"><div class="card-body"><h1 class="display-4 text-success">@ViewBag.AverageScore%</h1><p>Средний результат</p></div></div></div>
        <div class="col-md-3"><div class="card text-center border-warning"><div class="card-body"><h1 class="display-4 text-warning">@ViewBag.BestScore%</h1><p>Лучший результат</p></div></div></div>
    </div>

    <h4>📋 Последние результаты</h4>
    @if (Model.Any())
    {
        <table class="table table-striped"><thead><tr><th>Тест</th><th>Результат</th><th>Время</th><th>Дата</th><th>Прогресс</th></tr></thead><tbody>@foreach (var r in Model.Take(20)) { var ts = TimeSpan.FromSeconds(r.TimeSpentSeconds); <tr><td>@(r.Test?.Title ?? "—")</td><td><span class="badge @(r.Percentage >= 80 ? "bg-success" : r.Percentage >= 50 ? "bg-warning text-dark" : "bg-danger")">@r.Percentage%</span></td><td>@(ts.TotalMinutes >= 1 ? $"{(int)ts.TotalMinutes} мин {ts.Seconds} сек" : $"{ts.Seconds} сек")</td><td>@r.CompletedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td><td><div class="progress" style="height:10px;"><div class="progress-bar @(r.Percentage >= 80 ? "bg-success" : r.Percentage >= 50 ? "bg-warning" : "bg-danger")" style="width:@r.Percentage%;"></div></div></td></tr> }</tbody></table>
    }
    else { <div class="alert alert-info">Вы ещё не прошли ни одного теста. <a href="/Test" class="btn btn-primary btn-sm ms-2">Перейти</a></div> }

    <h4>📋 Результаты экзаменов</h4>
    @if (((List<ExamSubmission>)ViewBag.ExamResults).Any())
    {
        <table class="table table-striped"><thead><tr><th>Экзамен</th><th>Дата</th><th>Оценка</th><th>Статус</th></tr></thead><tbody>@foreach (var s in (List<ExamSubmission>)ViewBag.ExamResults) { <tr><td>@s.Exam?.Title</td><td>@s.SubmittedAt.ToLocalTime().ToString("dd.MM HH:mm")</td><td>@(s.Score?.ToString() ?? "—")</td><td>@(s.Score == null ? "⏳ На проверке" : "✅ Проверено")</td></tr> }</tbody></table>
    }
</div>