@{
    ViewData["Title"] = "Вход в систему";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-body p-5">
                    <h1 class="text-center mb-4">📚 Тренажёр сотрудника</h1>
                    <h5 class="text-center text-muted mb-4">Вход в систему</h5>
                    @if (ViewBag.Error != null) { <div class="alert alert-danger">@ViewBag.Error</div> }
                    <form method="post">
                        <div class="mb-3"><label class="form-label">Логин</label><input type="text" name="username" class="form-control" placeholder="Введите логин" required autofocus /></div>
                        <div class="mb-3"><label class="form-label">Пароль</label><input type="password" name="password" class="form-control" placeholder="Введите пароль" required /></div>
                        <button type="submit" class="btn btn-primary w-100 btn-lg">🔐 Войти</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>