@model List<EmployeeTrainer.Models.HandbookArticle>

@{
    ViewData["Title"] = "Справочник";
}

<style>
    .tag-badge { cursor: pointer; transition: all 0.2s; user-select: none; }
    .tag-badge:hover { opacity: 0.8; }
    .tag-badge.active { background-color: #3498db !important; }
    .tags-panel { max-height: 200px; overflow-y: auto; padding: 10px; background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 10px; }
</style>

<div class="container mt-4">
    <h2>📚 Справочник</h2>

    <form method="get" class="mb-3">
        <div class="row">
            <div class="col-md-6 mb-2">
                <div class="input-group">
                    <input type="text" name="search" id="searchInput" class="form-control" placeholder="Поиск по названию..." value="@ViewBag.Search" />
                    <input type="hidden" name="tags" id="selectedTags" />
                    <button type="submit" class="btn btn-primary">🔍</button>
                    @if (!string.IsNullOrEmpty(ViewBag.Search as string)) { <a href="/Handbook" class="btn btn-outline-secondary">✕</a> }
                </div>
            </div>
            <div class="col-md-6 mb-2">
                <button type="button" class="btn btn-outline-info" onclick="toggleTags()">🏷️ Теги <span id="tagCount" class="badge bg-info ms-1">0</span></button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="clearAllTags()" id="clearTagsBtn" style="display:none;">✕ Сбросить</button>
            </div>
        </div>
        <div id="tagsPanel" class="tags-panel mb-2" style="display:none;">
            <input type="text" id="tagFilter" class="form-control form-control-sm mb-2" placeholder="Фильтр тегов..." onkeyup="filterTags()" />
            <div id="tagsList" class="d-flex flex-wrap gap-1">@if (ViewBag.Tags != null) { foreach (var tag in ViewBag.Tags) { <span class="badge bg-secondary tag-badge" data-tag="@tag" onclick="toggleTag(this,'@tag')">#@tag</span> } }</div>
        </div>
    </form>

    @if (Model.Any())
    {
        <div class="list-group">@foreach (var article in Model) { <a href="/Handbook/Details/@article.Id" class="list-group-item list-group-item-action"><div class="d-flex justify-content-between"><h5>@article.Title</h5>@if (!string.IsNullOrEmpty(article.Tags)) { <small class="text-muted">@foreach (var tag in article.Tags.Split(',')) { <span class="badge bg-secondary me-1">@tag.Trim()</span> }</small> }</div></a> }</div>
    }
    else { <div class="alert alert-info">Ничего не найдено</div> }
</div>

@section Scripts {
    <script>
        var selectedTags = [], panelVisible = false;
        var urlParams = new URLSearchParams(window.location.search);
        var tagsParam = urlParams.get('tags');
        if (tagsParam) { selectedTags = tagsParam.split(',').filter(function(t) { return t.length > 0; }); }
        updateUI();
        function toggleTags() { panelVisible = !panelVisible; document.getElementById('tagsPanel').style.display = panelVisible ? 'block' : 'none'; if (panelVisible) document.getElementById('tagFilter').focus(); }
        function toggleTag(el, tag) { var idx = selectedTags.indexOf(tag); if (idx >= 0) { selectedTags.splice(idx, 1); el.classList.remove('active'); } else { selectedTags.push(tag); el.classList.add('active'); } updateUI(); }
        function filterTags() { var f = document.getElementById('tagFilter').value.toLowerCase(); document.querySelectorAll('#tagsList .tag-badge').forEach(function(b) { b.style.display = b.dataset.tag.toLowerCase().includes(f) ? 'inline-block' : 'none'; }); }
        function clearAllTags() { selectedTags = []; updateUI(); }
        function updateUI() { document.getElementById('selectedTags').value = selectedTags.join(','); document.getElementById('tagCount').textContent = selectedTags.length; document.getElementById('clearTagsBtn').style.display = selectedTags.length > 0 ? 'inline-block' : 'none'; document.querySelectorAll('#tagsList .tag-badge').forEach(function(b) { b.classList.toggle('active', selectedTags.indexOf(b.dataset.tag) >= 0); }); }
    </script>
}