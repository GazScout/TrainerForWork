@model List<EmployeeTrainer.Models.AuditLog>

@{
    ViewData["Title"] = "Журнал действий";
}

<div class="container mt-4">
    <h2>📋 Журнал действий</h2>
    <a href="/Admin" class="btn btn-outline-secondary mb-3">← Назад</a>

    <p>Всего записей: <strong>@Model.Count</strong></p>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-sm">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Дата / Время</th>
                        <th>Пользователь</th>
                        <th>Действие</th>
                        <th>Тип</th>
                        <th>Детали</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td>@log.Id</td>
                            <td>@log.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>
                            <td>@(log.User?.Username ?? "Система")</td>
                            <td>
                                @switch (log.Action)
                                {
                                    case "Create":
                                        <span class="badge bg-success">Создание</span>
                                        break;
                                    case "Update":
                                        <span class="badge bg-warning text-dark">Изменение</span>
                                        break;
                                    case "Delete":
                                        <span class="badge bg-danger">Удаление</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">@log.Action</span>
                                        break;
                                }
                            </td>
                            <td>@log.EntityType</td>
                            <td><small>@log.Details</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <h5>🔍 Журнал пуст</h5>
            <p>Выполните любое действие в админке и обновите страницу.</p>
        </div>
    }
</div>