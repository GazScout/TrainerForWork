@model List<EmployeeTrainer.Models.AuditLog>

@{
    ViewData["Title"] = "Журнал действий";
    var currentAction = ViewBag.LogAction as string;
    var currentEntityType = ViewBag.EntityType as string;
    var search = ViewBag.Search as string;
    int currentPage = ViewBag.CurrentPage != null ? Convert.ToInt32(ViewBag.CurrentPage) : 1;
    int totalPages = ViewBag.TotalPages != null ? Convert.ToInt32(ViewBag.TotalPages) : 1;
}

<div class="container mt-4">
    <h2>📋 Журнал действий</h2>
    <a href="/Admin" class="btn btn-outline-secondary mb-3">← Назад</a>

    <form method="get" class="row mb-3">
        <div class="col-md-3 mb-2">
            <select name="logAction" class="form-select" onchange="this.form.submit()">
                <option value="">Все действия</option>
                <option value="Create" selected="@(currentAction == "Create")">Создание</option>
                <option value="Update" selected="@(currentAction == "Update")">Изменение</option>
                <option value="Delete" selected="@(currentAction == "Delete")">Удаление</option>
                <option value="Login" selected="@(currentAction == "Login")">Вход</option>
                <option value="Logout" selected="@(currentAction == "Logout")">Выход</option>
            </select>
        </div>
        <div class="col-md-3 mb-2">
            <select name="entityType" class="form-select" onchange="this.form.submit()">
                <option value="">Все типы</option>
                <option value="Test" selected="@(currentEntityType == "Test")">Тесты</option>
                <option value="Question" selected="@(currentEntityType == "Question")">Вопросы</option>
                <option value="User" selected="@(currentEntityType == "User")">Пользователи</option>
                <option value="Article" selected="@(currentEntityType == "Article")">Статьи</option>
                <option value="Task" selected="@(currentEntityType == "Task")">Задания</option>
                <option value="Exam" selected="@(currentEntityType == "Exam")">Экзамены</option>
                <option value="Report" selected="@(currentEntityType == "Report")">Репорты</option>
            </select>
        </div>
        <div class="col-md-4 mb-2">
            <input type="text" name="search" class="form-control" placeholder="Поиск по деталям..." value="@search" />
        </div>
        <div class="col-md-2 mb-2">
            <button type="submit" class="btn btn-primary w-100">🔍</button>
            @if (!string.IsNullOrEmpty(currentAction) || !string.IsNullOrEmpty(currentEntityType) || !string.IsNullOrEmpty(search))
            {
                <a href="/Admin/AuditLog" class="btn btn-outline-secondary w-100 mt-1">✕ Сброс</a>
            }
        </div>
    </form>

    <p>Всего записей: <strong>@ViewBag.TotalItems</strong> | Страница <strong>@currentPage</strong> из <strong>@totalPages</strong></p>

    <table class="table table-striped table-sm">
        <thead>
            <tr><th>ID</th><th>Дата / Время</th><th>Пользователь</th><th>Действие</th><th>Тип</th><th>Детали</th></tr>
        </thead>
        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td>@log.Id</td>
                    <td>@log.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>
                    <td>@(log.User?.Username ?? "Система")</td>
                    <td>
                        @switch (log.Action)
                        {
                            case "Create": <span class="badge bg-success">Создание</span>; break;
                            case "Update": <span class="badge bg-warning text-dark">Изменение</span>; break;
                            case "Delete": <span class="badge bg-danger">Удаление</span>; break;
                            case "Login": <span class="badge bg-info">Вход</span>; break;
                            case "Logout": <span class="badge bg-secondary">Выход</span>; break;
                            default: <span class="badge bg-dark">@log.Action</span>; break;
                        }
                    </td>
                    <td>@log.EntityType</td>
                    <td><small>@log.Details</small></td>
                </tr>
            }
        </tbody>
    </table>

    @if (totalPages > 1)
    {
        <nav>
            <ul class="pagination">
                @if (currentPage > 1)
                {
                    <li class="page-item"><a class="page-link" href="/Admin/AuditLog?page=@(currentPage-1)&logAction=@currentAction&entityType=@currentEntityType&search=@search">←</a></li>
                }
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")"><a class="page-link" href="/Admin/AuditLog?page=@i&logAction=@currentAction&entityType=@currentEntityType&search=@search">@i</a></li>
                }
                @if (currentPage < totalPages)
                {
                    <li class="page-item"><a class="page-link" href="/Admin/AuditLog?page=@(currentPage+1)&logAction=@currentAction&entityType=@currentEntityType&search=@search">→</a></li>
                }
            </ul>
        </nav>
    }
</div>