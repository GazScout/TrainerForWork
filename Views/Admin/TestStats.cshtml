@model List<EmployeeTrainer.Models.TestResult>

@{
    ViewData["Title"] = "Статистика тестов";
}

<div class="container mt-4">
    <h2>📊 Статистика прохождения тестов</h2>
    <a href="/Admin/Tests" class="btn btn-outline-secondary mb-3">← К тестам</a>

    <table class="table table-striped">
        <thead><tr><th>Сотрудник</th><th>Тест</th><th>Результат</th><th>Время</th><th>Дата</th></tr></thead>
        <tbody>
            @foreach (var r in Model)
            {
                var ts = TimeSpan.FromSeconds(r.TimeSpentSeconds);
                <tr>
                    <td>@(r.User?.FullName ?? r.User?.Username ?? "—")</td>
                    <td>@(r.Test?.Title ?? "—")</td>
                    <td><span class="badge @(r.Percentage >= 80 ? "bg-success" : r.Percentage >= 50 ? "bg-warning text-dark" : "bg-danger")">@r.Score/@r.TotalQuestions (@r.Percentage%)</span></td>
                    <td>@(ts.TotalMinutes >= 1 ? $"{(int)ts.TotalMinutes} мин {ts.Seconds} сек" : $"{ts.Seconds} сек")</td>
                    <td>@r.CompletedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
</div>