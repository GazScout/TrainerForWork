@{
    ViewData["Title"] = "Админ-панель";
}

<div class="container mt-4">
    <h2>⚙️ Админ-панель</h2>
    
    <div class="row mt-4">
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">📖 Справочник</h5>
                    <p class="card-text">Управление статьями</p>
                    <a href="/Admin/Articles" class="btn btn-primary">Управлять</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">📝 Тесты</h5>
                    <p class="card-text">Управление тестами</p>
                    <a href="/Admin/Tests" class="btn btn-primary">Управлять</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">🔧 Тренажёр</h5>
                    <p class="card-text">Управление заданиями</p>
                    <a href="/Admin/TaskGroups" class="btn btn-primary">Управлять</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
    <div class="card h-100">
        <div class="card-body text-center">
            <h5 class="card-title">📋 Экзамены</h5>
            <p class="card-text">Управление экзаменами</p>
            <a href="/Admin/Exams" class="btn btn-primary">Управлять</a>
        </div>
    </div>
</div>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">👥 Пользователи</h5>
                    <p class="card-text">Управление доступом</p>
                    <a href="/Admin/Users" class="btn btn-primary">Управлять</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">📊 Статистика</h5>
                    <p class="card-text">Результаты тестов</p>
                    <a href="/Admin/TestStats" class="btn btn-primary">Просмотр</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">📋 Журнал</h5>
                    <p class="card-text">История изменений</p>
                    <a href="/Admin/AuditLog" class="btn btn-primary">Просмотр</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
    <div class="card h-100">
        <div class="card-body text-center">
            <h5 class="card-title">📋 Проверка экзаменов</h5>
            <p class="card-text">Оценка ответов</p>
            <a href="/Admin/ReviewExams" class="btn btn-primary">Проверить</a>
        </div>
    </div>
</div>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">🚩 Репорты</h5>
                    <p class="card-text">Сообщения об ошибках</p>
                    <a href="/Admin/Reports" class="btn btn-primary">Просмотр</a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="mt-3">
        <a href="/" class="btn btn-outline-secondary">← На главную</a>
    </div>
</div>