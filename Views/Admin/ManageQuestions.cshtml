@model EmployeeTrainer.Models.Test

@{
    ViewData["Title"] = "Вопросы теста";
}

<style>
    .question-editor { border: 1px solid var(--border-color); border-radius: 12px; padding: 20px; margin-bottom: 20px; }
    .option-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .option-row input[type="text"] { flex: 1; }
    .option-check { width: 24px; height: 24px; cursor: pointer; }
    .add-option-btn { cursor: pointer; color: #3498db; font-size: 0.9rem; }
    .add-option-btn:hover { color: #2980b9; }
    .remove-option { cursor: pointer; color: #e74c3c; font-size: 1.2rem; }
    .existing-question { border-left: 3px solid #3498db; padding-left: 15px; margin-bottom: 10px; }
</style>

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Admin/Tests">Тесты</a></li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>

    <h2>📝 @Model.Title</h2>
    <p class="text-muted">@Model.Description</p>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <!-- Настройки теста -->
    <div class="card mb-4">
        <div class="card-header">⚙️ Настройки теста</div>
        <div class="card-body">
            <form method="post" action="/Admin/UpdateTestSettings" class="row">
                <input type="hidden" name="testId" value="@Model.Id" />
                <div class="col-md-3 mb-2">
                    <label class="form-label">⏱️ Время (мин)</label>
                    <input type="number" name="timeLimitMinutes" class="form-control" 
                           value="@Model.TimeLimitMinutes" min="0" />
                </div>
                <div class="col-md-3 mb-2 d-flex align-items-end">
                    <div class="form-check">
                        <input type="hidden" name="shuffleQuestions" value="false" />
                        <input type="checkbox" name="shuffleQuestions" value="true" 
                               class="form-check-input" id="shuffleEdit"
                               @(Model.ShuffleQuestions ? "checked" : "") />
                        <label class="form-check-label" for="shuffleEdit">🔀 Перемешивать</label>
                    </div>
                </div>
                <div class="col-md-3 mb-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary">💾 Сохранить</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Создание вопроса -->
    <div class="question-editor">
        <h5>+ Новый вопрос</h5>
        <form id="addQuestionForm">
            <input type="hidden" name="testId" value="@Model.Id" />
            <input type="hidden" name="OptionsJson" id="OptionsJson" />
            <input type="hidden" name="CorrectAnswersJson" id="CorrectAnswersJson" />
            <input type="hidden" name="AllowMultipleCorrect" id="AllowMultipleCorrect" value="false" />
            
            <div class="mb-3">
                <label class="form-label">Текст вопроса</label>
                <input type="text" name="questionText" class="form-control" required 
                       placeholder="Введите вопрос" />
            </div>
            
            <div class="mb-2">
                <label class="form-label">Варианты ответа</label>
                <div class="form-check mb-2">
                    <input type="checkbox" class="form-check-input" id="multipleMode" 
                           onchange="toggleMultipleMode()" />
                    <label class="form-check-label" for="multipleMode">
                        ☑️ Несколько правильных ответов
                    </label>
                </div>
            </div>
            
            <div id="optionsContainer">
                <!-- Варианты добавляются через JS -->
            </div>
            
            <a class="add-option-btn" onclick="addOption()">+ Добавить вариант</a>
            
            <div class="mt-3">
                <button type="button" class="btn btn-success" onclick="submitQuestion()">➕ Добавить вопрос</button>
            </div>
        </form>
    </div>

    <!-- Существующие вопросы -->
    <h4>Существующие вопросы (@Model.Questions.Count)</h4>
    @if (Model.Questions.Any())
    {
        @foreach (var q in Model.Questions.OrderBy(q => q.OrderIndex))
{
    var options = string.IsNullOrEmpty(q.OptionsJson) 
        ? new List<string>() 
        : System.Text.Json.JsonSerializer.Deserialize<List<string>>(q.OptionsJson) ?? new List<string>();
    var correctIndexes = string.IsNullOrEmpty(q.CorrectAnswersJson)
        ? new List<int>()
        : System.Text.Json.JsonSerializer.Deserialize<List<int>>(q.CorrectAnswersJson) ?? new List<int>();
    
    <div class="existing-question mb-3">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <strong>@q.Question</strong>
                <span class="badge bg-info ms-2">@(q.AllowMultipleCorrect ? "☑️ Несколько" : "○ Один")</span>
                <div class="mt-1">
                    @for (int i = 0; i < options.Count; i++)
                    {
                        <span class="me-2 @(correctIndexes.Contains(i) ? "text-success fw-bold" : "")">
                            @(correctIndexes.Contains(i) ? "✅" : "○") @options[i]
                        </span>
                    }
                </div>
            </div>
            <div class="d-flex gap-1">
                <a href="/Admin/EditQuestion/@q.Id" class="btn btn-sm btn-warning">✏️</a>
                <form method="post" action="/Admin/DeleteQuestionFromTest" style="display:inline">
                    <input type="hidden" name="questionId" value="@q.Id" />
                    <input type="hidden" name="testId" value="@Model.Id" />
                    <button class="btn btn-sm btn-danger" onclick="return confirm('Удалить вопрос?')">🗑️</button>
                </form>
            </div>
        </div>
    </div>
}
    }
    else
    {
        <p class="text-muted">Вопросов пока нет</p>
    }
</div>

@section Scripts {
    <script>
        var optionCount = 0;
        var isMultiple = false;

        // Добавить 2 пустых варианта при загрузке
        addOption();
        addOption();

        function toggleMultipleMode() {
            isMultiple = document.getElementById('multipleMode').checked;
            document.getElementById('AllowMultipleCorrect').value = isMultiple;
            
            var checks = document.querySelectorAll('.option-check');
            checks.forEach(function(c) {
                c.type = isMultiple ? 'checkbox' : 'radio';
            });
            
            // Сбросить выбранные при переключении
            checks.forEach(function(c) { c.checked = false; });
        }

        function addOption() {
            optionCount++;
            var container = document.getElementById('optionsContainer');
            var div = document.createElement('div');
            div.className = 'option-row';
            div.innerHTML = 
                '<input type="' + (isMultiple ? 'checkbox' : 'radio') + '" ' +
                'name="correctOption" value="' + (optionCount - 1) + '" class="form-check-input option-check" />' +
                '<input type="text" class="form-control option-text" placeholder="Вариант ответа" required />' +
                '<span class="remove-option" onclick="this.parentElement.remove()">✕</span>';
            container.appendChild(div);
        }

        function submitQuestion() {
            var texts = document.querySelectorAll('#optionsContainer .option-text');
            var checks = document.querySelectorAll('#optionsContainer .option-check');
            
            if (texts.length < 2) {
                alert('Добавьте хотя бы 2 варианта ответа');
                return;
            }

            var options = [];
            var correctIndexes = [];
            
            texts.forEach(function(t, i) {
                if (t.value.trim()) {
                    options.push(t.value.trim());
                    if (checks[i].checked) {
                        correctIndexes.push(options.length - 1);
                    }
                }
            });

            document.getElementById('OptionsJson').value = JSON.stringify(options);
            document.getElementById('CorrectAnswersJson').value = JSON.stringify(correctIndexes);

            // Отправляем форму
            var form = document.getElementById('addQuestionForm');
            var fd = new FormData();
            fd.append('testId', '@Model.Id');
            fd.append('questionText', form.querySelector('[name="questionText"]').value);
            fd.append('OptionsJson', document.getElementById('OptionsJson').value);
            fd.append('CorrectAnswersJson', document.getElementById('CorrectAnswersJson').value);
            fd.append('AllowMultipleCorrect', isMultiple);

            fetch('/Admin/AddQuestionJson', {
                method: 'POST',
                body: fd
            }).then(function() {
                location.reload();
            });
        }
    </script>
}