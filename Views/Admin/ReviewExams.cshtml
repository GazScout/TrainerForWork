@model List<EmployeeTrainer.Models.ExamSubmission>

@{
    ViewData["Title"] = "Проверка экзаменов";
}

<div class="container mt-4">
    <h2>📋 Экзамены на проверку</h2>
    <a href="/Admin" class="btn btn-outline-secondary mb-3">← Назад</a>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (Model.Any())
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Сотрудник</th>
                    <th>Экзамен</th>
                    <th>Дата</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sub in Model)
                {
                    <tr>
                        <td>@sub.Id</td>
                        <td>@(sub.User?.FullName ?? sub.User?.Username ?? "—")</td>
                        <td>@(sub.Exam?.Title ?? "—")</td>
                        <td>@sub.SubmittedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <button class="btn btn-sm btn-primary" data-bs-toggle="modal" 
                                    data-bs-target="#reviewModal@(sub.Id)">📝 Проверить</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @foreach (var sub in Model)
        {
            var answers = string.IsNullOrEmpty(sub.AnswersJson)
                ? new Dictionary<string, string>()
                : System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(sub.AnswersJson) ?? new();
            var tasks = sub.Exam?.Tasks ?? new List<ExamTask>();

            <div class="modal fade" id="reviewModal@(sub.Id)" tabindex="-1">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <form method="post" action="/Admin/ReviewExamSubmission">
                            <input type="hidden" name="submissionId" value="@sub.Id" />
                            <div class="modal-header">
                                <h5>📝 Проверка: @sub.Exam?.Title</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <p><strong>Сотрудник:</strong> @(sub.User?.FullName ?? sub.User?.Username)</p>
                                <p><strong>Дата:</strong> @sub.SubmittedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
                                <hr />

                                @foreach (var task in tasks.OrderBy(t => t.OrderIndex))
                                {
                                    var userAnswer = answers.GetValueOrDefault(task.Id.ToString(), "—");
                                    var options = string.IsNullOrEmpty(task.OptionsJson)
                                        ? new List<string>()
                                        : task.OptionsJson.Split('|').Select(o => o.Trim()).ToList();

                                    <div class="card mb-2">
                                        <div class="card-header">
                                            <strong>@task.Title</strong>
                                            <span class="badge bg-info ms-2">
                                                @(task.Type == ExamTaskType.Single ? "○ Один" : task.Type == ExamTaskType.Multiple ? "☑️ Несколько" : "✍️ Свободный")
                                            </span>
                                        </div>
                                        <div class="card-body">
                                            <p>@task.Question</p>
                                            @if (!string.IsNullOrEmpty(task.ImageUrl))
                                            {
                                                <img src="@task.ImageUrl" class="img-fluid rounded mb-2" style="max-height:150px;" />
                                            }
                                            <p><strong>Ответ сотрудника:</strong> @userAnswer</p>
                                            @if (task.Type != ExamTaskType.Free)
                                            {
                                                var correctIndexes = string.IsNullOrEmpty(task.CorrectAnswersJson)
                                                    ? new List<int>()
                                                    : System.Text.Json.JsonSerializer.Deserialize<List<int>>(task.CorrectAnswersJson) ?? new List<int>();
                                                <p><strong>Правильные ответы:</strong> 
                                                    @string.Join(", ", correctIndexes.Select(i => i >= 0 && i < options.Count ? options[i] : "?"))
                                                </p>
                                            }
                                        </div>
                                    </div>
                                }

                                <hr />
                                <div class="row">
                                    <div class="col-md-6">
                                        <label class="form-label">Оценка (0-100)</label>
                                        <input type="number" name="score" class="form-control" min="0" max="100" required />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Комментарий</label>
                                        <textarea name="comment" class="form-control" rows="2" 
                                                  placeholder="Пояснение для сотрудника"></textarea>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                                <button type="submit" class="btn btn-success">✅ Выставить оценку</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info">Нет экзаменов на проверку.</div>
    }
</div>