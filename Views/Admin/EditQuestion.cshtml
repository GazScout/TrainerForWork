@{
    ViewData["Title"] = "Редактирование вопроса";
    var questionId = ViewBag.QuestionId;
    var questionText = ViewBag.QuestionText as string ?? "";
    var optionsText = ViewBag.Options as string ?? "";
    var correctAnswersJson = ViewBag.CorrectAnswersJson as string ?? "[0]";
    var allowMultiple = ViewBag.AllowMultipleCorrect as bool? ?? false;
    var testId = ViewBag.TestId;
    var options = optionsText.Split('\n', StringSplitOptions.RemoveEmptyEntries).Select(o => o.Trim()).ToList();
    var correctIndexes = string.IsNullOrEmpty(correctAnswersJson) ? new List<int> { 0 } : System.Text.Json.JsonSerializer.Deserialize<List<int>>(correctAnswersJson) ?? new List<int> { 0 };
}

<style>
    .option-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .option-row input[type="text"] { flex: 1; }
    .add-option-btn { cursor: pointer; color: #3498db; font-size: 0.9rem; }
    .add-option-btn:hover { color: #2980b9; }
    .remove-option { cursor: pointer; color: #e74c3c; font-size: 1.2rem; }
</style>

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Admin/Tests">Тесты</a></li>
            <li class="breadcrumb-item"><a href="/Admin/ManageQuestions?testId=@testId">Вопросы теста</a></li>
            <li class="breadcrumb-item active">Редактирование</li>
        </ol>
    </nav>

    <h2>✏️ Редактирование вопроса</h2>

    <form method="post" action="/Admin/EditQuestion/@questionId" id="editForm">
        <input type="hidden" name="testId" value="@testId" />
        <input type="hidden" name="OptionsJson" id="OptionsJson" />
        <input type="hidden" name="CorrectAnswersJson" id="CorrectAnswersJson" />
        <input type="hidden" name="AllowMultipleCorrect" id="AllowMultipleCorrect" value="@allowMultiple.ToString().ToLower()" />

        <div class="mb-3"><label class="form-label">Текст вопроса</label><input type="text" name="questionText" class="form-control" value="@questionText" required /></div>

        <div class="mb-2">
            <label class="form-label">Варианты ответа</label>
            <div class="form-check mb-2">
                <input type="checkbox" class="form-check-input" id="multipleMode" @(allowMultiple ? "checked" : "") onchange="toggleMultiple()" />
                <label class="form-check-label" for="multipleMode">☑️ Несколько правильных ответов</label>
            </div>
        </div>

        <div id="optionsContainer">
            @for (int i = 0; i < options.Count; i++)
            {
                <div class="option-row">
                    <input type="@(allowMultiple ? "checkbox" : "radio")" name="correctOption" value="@i" class="form-check-input option-check" @(correctIndexes.Contains(i) ? "checked" : "") />
                    <input type="text" class="form-control option-text" value="@options[i]" required />
                    <span class="remove-option" onclick="this.parentElement.remove()">✕</span>
                </div>
            }
        </div>
        <a class="add-option-btn" onclick="addOption()">+ Добавить вариант</a>

        <div class="mt-3"><label class="form-label">💡 Пояснение (показывается при ошибке)</label><input type="text" name="Explanation" class="form-control" value="@ViewBag.Explanation" /></div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">💾 Сохранить</button>
            <a href="/Admin/ManageQuestions?testId=@testId" class="btn btn-outline-secondary">Отмена</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        var isMultiple = @allowMultiple.ToString().ToLower();
        function toggleMultiple() { isMultiple = document.getElementById('multipleMode').checked; document.getElementById('AllowMultipleCorrect').value = isMultiple; document.querySelectorAll('.option-check').forEach(c => { c.type = isMultiple ? 'checkbox' : 'radio'; c.checked = false; }); }
        function addOption() { var c = document.getElementById('optionsContainer'), idx = c.querySelectorAll('.option-row').length, d = document.createElement('div'); d.className = 'option-row'; d.innerHTML = '<input type="' + (isMultiple ? 'checkbox' : 'radio') + '" name="correctOption" value="' + idx + '" class="form-check-input option-check" /><input type="text" class="form-control option-text" placeholder="Вариант" required /><span class="remove-option" onclick="this.parentElement.remove()">✕</span>'; c.appendChild(d); }
        document.getElementById('editForm').addEventListener('submit', function() { var texts = document.querySelectorAll('#optionsContainer .option-text'), checks = document.querySelectorAll('#optionsContainer .option-check'), opts = [], cis = []; texts.forEach((t, i) => { if (t.value.trim()) { opts.push(t.value.trim()); if (checks[i].checked) cis.push(opts.length - 1); } }); document.getElementById('OptionsJson').value = JSON.stringify(opts); document.getElementById('CorrectAnswersJson').value = JSON.stringify(cis); });
    </script>
}