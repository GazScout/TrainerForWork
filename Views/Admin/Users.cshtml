@model List<EmployeeTrainer.Models.User>
@using EmployeeTrainer.Models

@{
    ViewData["Title"] = "Управление пользователями";
}

<style>
    .table tr.current-user-row,
    .table tr.current-user-row td,
    .table tr.current-user-row th {
        background-color: rgba(52, 152, 219, 0.35) !important;
        color: #ffffff !important;
        font-weight: 500;
    }
    .table tr.current-user-row .text-muted {
        color: #cccccc !important;
    }
</style>

<div class="container mt-4">
    <h2>👥 Управление пользователями</h2>
    
    <a href="/Admin" class="btn btn-outline-secondary mb-3">← Назад</a>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <!-- Форма создания пользователя -->
    <div class="card mb-4">
        <div class="card-header">+ Создать нового сотрудника</div>
        <div class="card-body">
            <form method="post" action="/Admin/CreateUser">
                <div class="row">
                    <div class="col-md-3 mb-2">
                        <input type="text" name="username" class="form-control" 
                               placeholder="Логин" required />
                    </div>
                    <div class="col-md-3 mb-2">
                        <input type="password" name="password" class="form-control" 
                               placeholder="Пароль" required />
                    </div>
                    <div class="col-md-2 mb-2">
                        <input type="text" name="fullName" class="form-control" 
                               placeholder="ФИО" />
                    </div>
                    <div class="col-md-2 mb-2">
                        <select name="role" class="form-control">
                            <option value="0">👤 Сотрудник</option>
                            <option value="1">👑 Админ</option>
                        </select>
                    </div>
                    <div class="col-md-2 mb-2">
                        <button type="submit" class="btn btn-success w-100">➕ Создать</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Поиск -->
    <form method="get" class="d-flex mb-3 justify-content-end">
        <input type="text" name="search" class="form-control me-2" style="max-width: 250px;" 
               placeholder="Поиск по логину или ФИО..." value="@Context.Request.Query["search"]">
        <button type="submit" class="btn btn-primary">🔍</button>
        @if (!string.IsNullOrEmpty(Context.Request.Query["search"]))
        {
            <a href="/Admin/Users" class="btn btn-outline-secondary ms-1">✕</a>
        }
    </form>

    <!-- Таблица пользователей -->
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Логин</th>
                <th>ФИО</th>
                <th>Роль</th>
                <th>Статус</th>
                <th>Дата создания</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                var isSuperAdmin = user.Role == UserRole.SuperAdmin;
                var isCurrentUser = user.Id == (int?)ViewBag.CurrentUserId;
                
                <tr>
                    <td>@user.Id</td>
                    <td>
                        @user.Username
                        @if (isCurrentUser)
                        {
                            <span class="badge bg-info">Вы</span>
                        }
                    </td>
                    <td>@user.FullName</td>
                    <td>
                        @switch (user.Role)
                        {
                            case UserRole.SuperAdmin:
                                <span class="badge bg-warning text-dark">👑 Супер-админ</span>
                                break;
                            case UserRole.Admin:
                                <span class="badge bg-primary">👑 Админ</span>
                                break;
                            case UserRole.Employee:
                                <span class="badge bg-secondary">👤 Сотрудник</span>
                                break;
                        }
                    </td>
                    <td>
                        <span class="badge @(user.IsActive ? "bg-success" : "bg-danger")">
                            @(user.IsActive ? "Активен" : "Заблокирован")
                        </span>
                    </td>
                    <td>@user.CreatedAt.ToShortDateString()</td>
                    <td>
                        @if (isSuperAdmin)
                        {
                            <span class="text-muted">Защищён</span>
                        }
                        else
                        {
                            <div class="d-flex gap-1 flex-wrap">
                                <!-- Смена роли -->
                                <form method="post" action="/Admin/ChangeUserRole" style="display:inline">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <select name="newRole" class="form-select form-select-sm d-inline-block" 
                                            style="width: 120px;" onchange="this.form.submit()"
                                            @(isCurrentUser ? "disabled" : "")>
                                        <option value="0" selected="@(user.Role == UserRole.Employee)">👤 Сотрудник</option>
                                        <option value="1" selected="@(user.Role == UserRole.Admin)">👑 Админ</option>
                                    </select>
                                </form>
                                
                                <!-- Блокировка/разблокировка -->
                                @if (!isCurrentUser)
                                {
                                    <form method="post" action="/Admin/ToggleUserStatus" style="display:inline">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm @(user.IsActive ? "btn-warning" : "btn-success")"
                                                title="@(user.IsActive ? "Заблокировать" : "Разблокировать")">
                                            @(user.IsActive ? "🔒" : "🔓")
                                        </button>
                                    </form>
                                }
                                
                                <!-- Сброс пароля -->
                                @if (!isCurrentUser || isSuperAdmin)
                                {
                                    <button type="button" class="btn btn-sm btn-secondary" 
                                            data-bs-toggle="modal" data-bs-target="#resetModal@(user.Id)"
                                            title="Сбросить пароль">🔑</button>
                                }
                                
                                <!-- Удаление -->
                                @if (!isCurrentUser)
                                {
                                    <form method="post" action="/Admin/DeleteUser" style="display:inline">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger" 
                                                onclick="return confirm('Удалить пользователя @user.Username?')"
                                                title="Удалить">🗑️</button>
                                    </form>
                                }
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    
    <div class="card mt-4">
        <div class="card-body">
            <h5>📋 Иерархия ролей</h5>
            <ul>
                <li><strong>👑 Супер-админ</strong> — полный доступ, не может быть заблокирован или удалён</li>
                <li><strong>👑 Админ</strong> — управление контентом и сотрудниками (не может управлять другими админами)</li>
                <li><strong>👤 Сотрудник</strong> — только прохождение тестов и доступ к справочнику</li>
            </ul>
        </div>
    </div>
</div>

<!-- Модальные окна для сброса пароля -->
@foreach (var user in Model)
{
    var isSuperAdmin = user.Role == UserRole.SuperAdmin;
    var isCurrentUser = user.Id == (int?)ViewBag.CurrentUserId;
    
    if (!isSuperAdmin || isCurrentUser)
    {
        <div class="modal fade" id="resetModal@(user.Id)" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form method="post" action="/Admin/ResetPassword">
                        <input type="hidden" name="userId" value="@user.Id" />
                        <div class="modal-header">
                            <h5 class="modal-title">🔑 Сброс пароля: @user.Username</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <label class="form-label">Новый пароль</label>
                            <input type="password" name="newPassword" class="form-control" 
                                   required minlength="3" placeholder="Минимум 3 символа" />
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                            <button type="submit" class="btn btn-warning">🔑 Сбросить</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}