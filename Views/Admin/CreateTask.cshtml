@section Scripts {
    <script>
        function toggleLegend() { var b = document.getElementById('legendBox'); b.style.display = b.style.display === 'none' ? 'block' : 'none'; }
        function cycleMode(btn) {
            var modes = ['show', 'input', 'fix'], icons = ['🟢', '🟡', '🔴'];
            var cur = modes.indexOf(btn.classList.contains('show') ? 'show' : btn.classList.contains('input') ? 'input' : 'fix');
            var next = (cur + 1) % 3;
            btn.className = 'mode-btn ' + modes[next]; btn.textContent = icons[next];
            var row = btn.closest('.field-row');
            var adminVal = row.querySelector('.admin-value');
            var field = row.querySelector('.field-value');
            if (next === 0) { adminVal.classList.remove('visible'); field.disabled = false; field.style.opacity = '1'; }
            else if (next === 1) { adminVal.classList.add('visible'); field.disabled = false; field.style.opacity = '1'; field.value = ''; }
            else { adminVal.classList.add('visible'); field.disabled = true; field.style.opacity = '0.7'; }
        }
        document.getElementById('taskForm').addEventListener('submit', function() {
            var fields = [];
            document.querySelectorAll('.field-row').forEach(row => {
                var btn = row.querySelector('.mode-btn');
                var mode = btn.classList.contains('show') ? 'show' : btn.classList.contains('input') ? 'input' : 'fix';
                var value = row.querySelector('.field-value').value;
                var correct = row.querySelector('.admin-value').value;
                fields.push({ key: row.dataset.field, mode: mode, value: value, correct: correct });
            });
            document.getElementById('AnswerJson').value = JSON.stringify(fields);
            document.getElementById('ContentJson').value = document.querySelector('[name="Description"]').value;
        });
        function uploadImage(input) { var f = input.files[0]; if (!f) return; var fd = new FormData(); fd.append('image', f); fetch('/Admin/UploadImage', { method: 'POST', body: fd }).then(r => r.json()).then(d => { if (d.success) { document.getElementById('ImageUrl').value = d.url; document.getElementById('previewImg').src = d.url; document.getElementById('preview').style.display = 'block'; } else alert(d.error); }); }
    </script>
}