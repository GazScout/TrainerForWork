@model EmployeeTrainer.Models.SimulatorTask

@{
    ViewData["Title"] = "Новое задание";
}

<style>
    .order-topbar { background: var(--bg-card); border-radius: 10px; padding: 10px 15px; margin-bottom: 12px; display: flex; align-items: center; gap: 15px; flex-wrap: wrap; border: 1px solid var(--border-color); font-size: 0.85rem; }
    .order-id { font-size: 1.2rem; font-weight: 700; }
    .copy-btn { cursor: pointer; font-size: 0.8rem; color: var(--link-color); background: none; border: none; padding: 0 3px; }
    .order-date { font-size: 0.75rem; color: var(--text-muted); }
    .counter { background: var(--border-color); padding: 3px 10px; border-radius: 15px; font-weight: 600; font-size: 0.8rem; }
    .nav-btn { background: none; border: 1px solid var(--border-color); border-radius: 6px; padding: 4px 10px; cursor: pointer; color: var(--text-primary); font-size: 0.8rem; }
    .status-badge { padding: 4px 10px; border-radius: 15px; font-weight: 600; font-size: 0.78rem; }
    .status-work { background: #fff3cd; color: #856404; }
    .status-unpaid { background: #f8d7da; color: #721c24; }
    .section-card { background: var(--bg-card); border-radius: 10px; padding: 14px; border: 1px solid var(--border-color); margin-bottom: 12px; }
    .section-title { font-weight: 700; margin-bottom: 10px; font-size: 0.9rem; color: var(--text-primary); border-bottom: 2px solid #3498db; padding-bottom: 6px; display: inline-block; }
    .tabs { display: flex; }
    .tab-btn { padding: 7px 16px; border: 1px solid var(--border-color); background: var(--bg-card); cursor: pointer; color: var(--text-primary); font-size: 0.85rem; }
    .tab-btn.active { background: #3498db; color: #fff; border-color: #3498db; }
    .tab-btn:first-child { border-radius: 6px 0 0 6px; }
    .tab-btn:last-child { border-radius: 0 6px 6px 0; }
    .order-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
    .order-table th, .order-table td { padding: 6px 8px; border-bottom: 1px solid var(--border-color); text-align: left; }
    .order-table th { font-weight: 600; color: var(--text-muted); font-size: 0.75rem; }
    .money-block { text-align: right; font-size: 0.85rem; }
    .money-block div { margin-bottom: 3px; }
    .money-total { font-size: 1.1rem; font-weight: 700; }
    .btn-sm-sms { background: #27ae60; color: #fff; border: none; padding: 8px; border-radius: 6px; width: 100%; font-size: 0.8rem; cursor: pointer; margin-bottom: 6px; }
    .btn-sm-email { background: #2980b9; color: #fff; border: none; padding: 8px; border-radius: 6px; width: 100%; font-size: 0.8rem; cursor: pointer; margin-bottom: 6px; }
    .btn-sm-pay { background: #ecf0f1; color: #3498db; border: 1px solid #bdc3c7; padding: 8px; border-radius: 6px; width: 100%; font-size: 0.8rem; cursor: pointer; }
    .form-label.small { font-size: 0.75rem; margin-bottom: 2px; }
    .form-control-sm, .form-select-sm { font-size: 0.8rem; padding: 4px 8px; }
    .field-row { display: flex; align-items: center; gap: 6px; margin-bottom: 4px; flex-wrap: wrap; }
    .mode-btn { width: 28px; height: 28px; border-radius: 50%; border: 2px solid transparent; cursor: pointer; font-size: 0.9rem; display: flex; align-items: center; justify-content: center; background: var(--bg-card); transition: all 0.2s; flex-shrink: 0; }
    .mode-btn.show { background: #d5f5e3; border-color: #27ae60; }
    .mode-btn.input { background: #fef5e7; border-color: #f39c12; }
    .mode-btn.fix { background: #fadbd8; border-color: #e74c3c; }
    .admin-value { width: 130px; display: none; font-size: 0.7rem; padding: 2px 6px; flex-shrink: 0; }
    .admin-value.visible { display: inline-block; }
    .legend-box { display: inline-block; width: 14px; height: 14px; border-radius: 50%; margin-right: 4px; vertical-align: middle; }
    .legend-green { background: #d5f5e3; border: 1px solid #27ae60; }
    .legend-yellow { background: #fef5e7; border: 1px solid #f39c12; }
    .legend-red { background: #fadbd8; border: 1px solid #e74c3c; }
    .legend-toggle { cursor: pointer; color: #3498db; font-size: 0.8rem; }
</style>

